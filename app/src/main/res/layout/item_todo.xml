<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_todo"
    style="@style/Card.Todo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:layout_marginEnd="14dp">

        <View
            android:id="@+id/view_priority_bar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#6C63FF"
            android:layout_marginStart="-16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:background="@color/priority_high"/>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkbox_done"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            app:buttonTint="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <LinearLayout
            android:id="@+id/layout_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/checkbox_done"
            app:layout_constraintEnd_toStartOf="@id/tv_due_date">
            
            <TextView
                android:id="@+id/tv_todo_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="디자인 시스템 문서 작성하기"/>

            <TextView
                android:id="@+id/tv_todo_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="색상, 타이포, 컴포넌트 정리"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="visible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:background=""
                    tools:text="업무"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_priority_dot"
                    android:backgroundTint="@color/text_hint"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tv_deadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘 오후 6시"
                    android:textSize="12sp"
                    android:textColor="@color/accent_coral"
                    android:drawablePadding="3dp"
                    app:drawableStartCompat="@drawable/ic_schedule"
                    app:drawableTint="@color/accent_coral"
                    tools:text="오늘 오후 6시"/>

            </LinearLayout>
            
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src=""
            app:tint="@color/text_hint"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tv_due_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D-2"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_coral"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background=""
            android:layout_marginEnd="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_more"
            tools:visibility="visible"
            tools:text="D-2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
