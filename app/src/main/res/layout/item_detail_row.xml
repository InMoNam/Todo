<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 아이콘 배경 -->
    <LinearLayout
        android:id="@+id/icon_container"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_tag"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_row_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_calendar"
            app:tint="@color/primary"
            android:contentDescription="@null"
            tools:src="@drawable/ic_calendar"/>
    </LinearLayout>

    <!-- 라벨 텍스트 -->
    <TextView
        android:id="@+id/tv_row_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="마감일"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_hint"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@id/icon_container"
        app:layout_constraintStart_toEndOf="@id/icon_container"
        tools:text="마감일"/>

    <!-- 값 텍스트 -->
    <TextView
        android:id="@+id/tv_row_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2025년 1월 25일 오후 6시"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@id/icon_container"
        app:layout_constraintStart_toEndOf="@id/icon_container"
        tools:text="2025년 1월 25일 오후 6시"/>

</androidx.constraintlayout.widget.ConstraintLayout>