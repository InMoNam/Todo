<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:background="@color/surface">
        <View
            android:id="@+id/bottom_handle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_bottom_handle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"/>

        <!-- 화면 제목 -->
        <TextView
            android:id="@+id/tv_screen_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="새 할 일"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/bottom_handle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_close"/>

        <!-- 닫기 버튼 -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_input"
            android:src="@drawable/ic_close"
            android:contentDescription="닫기"
            app:tint="@color/text_secondary"
            android:padding="8dp"
            app:layout_constraintTop_toTopOf="@id/tv_screen_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_screen_title"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ===================================================
         SCROLLABLE FORM CONTENT
         =================================================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── 할 일 제목 입력 ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="제목 *"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_title"
                style="@style/Input.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="어떤 일을 해야 하나요?">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 설명 입력 ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="설명 (선택)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_description"
                style="@style/Input.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="메모나 상세 내용을 입력하세요">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:minLines="3"
                    android:maxLines="5"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── 카테고리 선택 ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="카테고리"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_work"
                    style="@style/Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏢 업무"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_personal"
                    style="@style/Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 개인"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_health"
                    style="@style/Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 건강"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_finance"
                    style="@style/Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 금융"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_other"
                    style="@style/Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기타"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- ── 우선순위 선택 ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="우선순위"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 높음 -->
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_priority"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_priority_high"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="🔴 높음"
                        android:textSize="13sp"
                        android:textColor="@color/priority_high"
                        app:strokeColor="@color/priority_high"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_priority_medium"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="🟡 중간"
                        android:textSize="13sp"
                        android:textColor="@color/priority_medium"
                        app:strokeColor="@color/priority_medium"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_priority_low"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="🟢 낮음"
                        android:textSize="13sp"
                        android:textColor="@color/priority_low"
                        app:strokeColor="@color/priority_low"/>

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>

            <!-- ── 마감일 선택 ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="마감일"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <!-- 날짜 선택 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_date"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="날짜를 선택하세요"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                app:icon="@drawable/ic_calendar"
                app:iconTint="@color/primary"
                app:iconGravity="start"
                app:strokeColor="@color/stroke"
                app:cornerRadius="16dp"/>

            <!-- 시간 선택 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_time"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="시간 선택 (선택)"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:layout_marginTop="8dp"
                app:icon="@drawable/ic_schedule"
                app:iconTint="@color/primary"
                app:iconGravity="start"
                app:strokeColor="@color/stroke"
                app:cornerRadius="16dp"/>

            <!-- 하단 여백 -->
            <Space android:layout_width="match_parent" android:layout_height="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- ===================================================
         BOTTOM ACTION BUTTONS
         =================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:elevation="8dp">

        <!-- 취소 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Button.Secondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="취소"
            android:layout_marginEnd="10dp"/>

        <!-- 저장 버튼 (그라디언트) -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="52dp"
            android:text="저장하기"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/bg_btn_primary"/>

    </LinearLayout>

</LinearLayout>